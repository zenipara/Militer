{
  "name": "karyo-os",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "env -u VITE_SUPABASE_URL -u VITE_SUPABASE_ANON_KEY vite",
    "build": "tsc -b && vite build",
    "sync:supabase": "bash scripts/sync-supabase.sh",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run src/tests",
    "test:watch": "vitest",
    "test:unit": "vitest run src/tests/**/*.{test,spec}.{ts,tsx}",
    "test:e2e": "vitest run src/tests/pages/**/*.test.tsx",
    "test:smoke:prod": "E2E_USE_WEBSERVER=false playwright test smoke-prod.spec.ts --project=chromium --reporter=line",
    "test:coverage": "vitest run --coverage",
    "test:prod:core": "E2E_USE_WEBSERVER=false playwright test smoke-prod.spec.ts gatepass-monitor.spec.ts --project=chromium --reporter=line",
    "test:prod:extended": "E2E_USE_WEBSERVER=false playwright test smoke-prod.spec.ts gatepass-monitor.spec.ts auth.spec.ts user-management.spec.ts logistics.spec.ts navigation.spec.ts search.spec.ts qrscanner.spec.ts --project=chromium --reporter=line"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.103.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^6.30.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.3.3",
    "vitest": "^3.2.4"
  }
}
